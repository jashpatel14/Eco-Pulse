# EcoPulse — Environment Configuration
# Format: Prisma v6 / Express / Node.js
# ---------------------------------------------------------

# [REQUIRED] Server Configuration
PORT=5000
NODE_ENV=development

# [REQUIRED] Database Configuration (Prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/EcoPulse"

# [OPTIONAL] Redis Configuration
REDIS_URL="redis://localhost:6379"

# [REQUIRED] Security — JWT Secrets
JWT_SECRET="your_jwt_secret_here"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_here"

# [REQUIRED] Client Configuration
CLIENT_URL="http://localhost:5173"
CORS_WHITELIST="http://localhost:5173,http://127.0.0.1:5173"

# [REQUIRED] Email Configuration (SMTP)
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=465
EMAIL_USER="your_email@gmail.com"
EMAIL_PASS="your_app_password_here"

# [REQUIRED] Auth Flags
REQUIRE_EMAIL_VERIFICATION="true"

# [OPTIONAL] Google OAuth
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"
GOOGLE_REDIRECT_URI="http://localhost:5000/api/v1/auth/google/callback"

# [OPTIONAL] Logging
LOG_LEVEL="info"
